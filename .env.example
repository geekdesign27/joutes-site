# Variables d'environnement à configurer pour Keystatic en mode GitHub
# Ces variables sont nécessaires UNIQUEMENT pour l'admin /keystatic en production.
# Le site public (lecture seule) fonctionne sans ces variables.

# GitHub OAuth App credentials — créés sur https://github.com/settings/developers
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=

# Secret aléatoire pour signer les sessions Keystatic
# Générer avec : openssl rand -hex 32
KEYSTATIC_SECRET=

# URL publique du site (pour les redirects OAuth)
KEYSTATIC_URL=https://joutesinterpompiers2026.ch
