---
import GridBackground from './GridBackground.astro';
import SponsorCard from './SponsorCard.astro';
import { getCollection } from 'astro:content';

// Tente de récupérer la collection Astro Content; sinon lit le dossier directement
let sponsors: Array<{
  name: string;
  url: string;
  logo: string;
  recolor: boolean;
  order: number;
}> = [];

try {
  const all = await getCollection('sponsors' as never);
  // @ts-expect-error - dynamic collection access
  sponsors = all.map((s) => ({ ...s.data, name: s.id })).sort((a, b) => a.order - b.order);
} catch {
  // Fallback : import direct des JSON via import.meta.glob
  const modules = import.meta.glob<{
    default: { name: string; url: string; logo: string; recolor: boolean; order: number };
  }>('../content/sponsors/*.json', { eager: true });
  sponsors = Object.values(modules)
    .map((m) => m.default)
    .sort((a, b) => (a.order ?? 0) - (b.order ?? 0));
}
---
<section class="sponsors" id="sponsors">
  <GridBackground variant="light" />
  <div class="wrap">
    <div class="sponsors-head">
      <div>
        <div class="eyebrow">Partenaires</div>
        <h2>
          Nos sponsors
          <span class="sub">Ils nous accompagnent</span>
        </h2>
      </div>
      <p>
        Les Joutes Inter-Pompiers de la Sarine ne pourraient exister sans le soutien précieux de nos partenaires. Entreprises locales et acteurs engagés contribuent activement à la réussite de cette manifestation, en partageant des valeurs communes : engagement, solidarité et esprit d'équipe.
      </p>
    </div>
    <div class="sponsor-grid">
      {sponsors.map((s) => (
        <SponsorCard name={s.name} url={s.url} logo={s.logo} recolor={s.recolor} />
      ))}
    </div>
  </div>
</section>

<style>
  .sponsors {
    position: relative;
    background: var(--color-cream);
    padding: calc(var(--cell-h) * 0.75) 0 calc(var(--cell-h) * 0.5);
    overflow: hidden;
    /* hauteur totale = 0.75 (pad top) + 1.25 (head) + 2 (grid) + 0.5 (pad bottom) = 4.5 cell-h
       sponsor-grid commence à 2 cell-h depuis top section → aligné sur la grille */
  }
  .sponsors-head {
    position: relative;
    z-index: 5;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    column-gap: 0;
    height: calc(var(--cell-h) * 1.25);
    margin-bottom: 0;
    align-items: center;
    transform: translateY(-100px);
  }
  .sponsors-head > div:first-child {
    grid-column: 1 / span 3;
    padding-right: 40px;
  }
  .sponsors-head > p {
    grid-column: 4 / span 3;
    margin-top: 70px;
  }
  .sponsors-head :global(.eyebrow) {
    color: var(--color-orange);
  }
  .sponsors h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 88px;
    line-height: .92;
    color: var(--color-orange);
    text-transform: uppercase;
  }
  .sponsors h2 .sub {
    display: block;
    font-family: var(--font-display);
    font-weight: 300;
    color: var(--color-ink);
    font-size: 42px;
    margin-top: 6px;
  }
  .sponsors-head p {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 18px;
    line-height: 1.65;
    color: #3a342c;
    max-width: 520px;
    text-wrap: pretty;
  }

  /* Grille de sponsors auto-fit alignée sur la 1re colonne du wrap */
  .sponsor-grid {
    position: relative;
    z-index: 5;
    display: grid;
    grid-template-columns: repeat(auto-fit, var(--cell-w));
    justify-content: start;
  }

  @media (max-width: 960px) {
    .sponsors {
      padding: 56px 0 40px;
    }
    .sponsors-head {
      grid-template-columns: 1fr;
      gap: 24px;
      height: auto;
      transform: none;
      margin-bottom: 48px;
    }
    .sponsors-head > div:first-child,
    .sponsors-head > p {
      grid-column: 1 / -1;
      padding-right: 0;
      margin-top: 0;
      max-width: none;
    }
    .sponsors h2 { font-size: 54px; }
    .sponsors h2 .sub { font-size: 28px; }
    .sponsor-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }
  }

  @media (max-width: 600px) {
    .sponsor-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .sponsors {
      padding: 40px 0 32px;
    }
    .sponsors h2 { font-size: 40px; }
    .sponsors h2 .sub { font-size: 22px; }
    .sponsors-head p { font-size: 16px; }
    .sponsors-head { margin-bottom: 32px; }
  }
</style>
