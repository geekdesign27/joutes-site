---
import GridBackground from './GridBackground.astro';
import heroData from '../content/sections/hero.json';
import siteData from '../content/settings/site.json';

const hasHeroBg = !!heroData.backgroundImage;
const heroBgUrl = heroData.backgroundImage || '';
---
<section class="hero" id="top">
  {hasHeroBg && (
    <img
      src={heroBgUrl}
      alt=""
      class="hero-bg-image"
      aria-hidden="true"
      loading="eager"
      fetchpriority="high"
    />
  )}
  <GridBackground variant="dark" />
  <div class="wrap hero-inner">
    <nav class="nav">
      <div class="nav-logo-wrap">
        <div class="nav-logo">
          <img src="/logo.svg" alt="Logo Joutes Inter-Pompiers de la Sarine 2026" />
        </div>
      </div>
      <div class="nav-links-wrap">
        <div class="nav-links">
          <a href="#programme">Programme</a>
          <a href="#match">Match Suisse-Qatar</a>
          <a href="#sponsors">Sponsors</a>
        </div>
      </div>
    </nav>

    <h1 class="hero-title-wrap">
      <span class="sr-only">{siteData.title}</span>
      <span class="hero-title" aria-hidden="true">
        <span class="line serif">{heroData.line1}</span>
        <span class="line sans">{heroData.line2}</span>
        <span class="line">
          <span class="serif">{heroData.line3a}</span>
          <span class="spacer"> </span>
          <span class="sans">{heroData.line3b}</span>
        </span>
      </span>
    </h1>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    color: #fff;
    height: calc(var(--cell-h) * 2.5);
    background:
      radial-gradient(70% 60% at 12% 75%, rgba(243,148,51,.55) 0%, rgba(243,148,51,0) 60%),
      radial-gradient(80% 70% at 100% 30%, rgba(11,14,40,.65) 0%, rgba(11,14,40,0) 60%),
      linear-gradient(160deg, #1B2447 0%, #2B2347 28%, #6F1D2E 55%, #B83A28 78%, #E8742C 100%);
  }
  .hero-bg-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.4;
    z-index: 0;
    mix-blend-mode: overlay;
  }
  .hero-inner {
    position: relative;
    z-index: 5;
    height: 100%;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: var(--cell-h) calc(var(--cell-h) * 1.5);
  }
  .nav {
    grid-column: 1 / -1;
    grid-row: 1;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    align-items: start;
    padding-top: 24px;
  }
  .nav-logo-wrap {
    grid-column: 1 / span 1;
    display: flex;
    align-items: flex-start;
  }
  .nav-links-wrap {
    grid-column: 6 / span 1;
    display: flex;
    justify-content: flex-end;
    align-items: flex-start;
  }
  .nav-logo {
    width: 120px;
    height: 120px;
  }
  .nav-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: brightness(0) saturate(100%) invert(60%) sepia(60%) saturate(1300%) hue-rotate(350deg) brightness(101%) contrast(95%) drop-shadow(0 2px 6px rgba(0,0,0,.35));
  }
  .nav-links {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.9;
    text-align: right;
    color: var(--color-cream-soft);
  }
  .nav-links a {
    color: inherit;
    text-decoration: none;
    display: block;
    cursor: pointer;
    transition: color .2s;
  }
  .nav-links a:hover {
    color: var(--color-orange-bright);
  }
  .hero-title-wrap {
    grid-column: 1 / -1;
    grid-row: 2;
    align-self: start;
    margin-top: -10px;
  }
  .hero-title {
    color: var(--color-orange-bright);
    text-transform: uppercase;
    line-height: .95;
    display: block;
  }
  .hero-title .line {
    display: block;
  }
  .hero-title .serif {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 114px;
    line-height: .95;
    letter-spacing: 0;
  }
  .hero-title .sans {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 100px;
    line-height: .95;
    letter-spacing: -0.005em;
  }
  .hero-title .spacer {
    display: inline-block;
    width: 0.3em;
  }

  @media (max-width: 960px) {
    .hero {
      height: auto;
      min-height: 90vh;
      padding-bottom: 56px;
    }
    .hero-inner {
      grid-template-rows: auto 1fr;
    }
    .nav { padding-top: 20px; }
    .hero-title-wrap { margin-top: 40px; }
    .hero-title .serif { font-size: 84px; }
    .hero-title .sans { font-size: 60px; }
    .nav-logo { width: 64px; height: 64px; }
  }

  @media (max-width: 600px) {
    .hero { min-height: 85vh; }
    .hero-title .serif { font-size: 60px; }
    .hero-title .sans { font-size: 44px; }
    .nav-logo { width: 52px; height: 52px; }
    .nav-links { font-size: 12px; line-height: 1.8; letter-spacing: .04em; }
    .nav-links a { padding: 4px 0; }
  }

  @media (max-width: 380px) {
    .hero-title .serif { font-size: 48px; }
    .hero-title .sans { font-size: 36px; }
    .nav-logo { width: 44px; height: 44px; }
    .nav-links { font-size: 11px; }
  }
</style>
