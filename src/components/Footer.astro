---
import GridBackground from './GridBackground.astro';
import siteData from '../content/settings/site.json';

const year = new Date().getFullYear();
---
<footer class="footer">
  <GridBackground variant="dark" />
  <div class="wrap">
    <div class="footer-inner">
      <div class="footer-logo">
        <img src="/logo.svg" alt="Logo Joutes Inter-Pompiers" />
      </div>
      <div class="footer-info">
        <div class="name">{siteData.organizationName}</div>
        <div>{siteData.addressStreet}</div>
        <div>{siteData.addressCity}</div>
      </div>
      <div class="footer-social">
        {siteData.instagramUrl && (
          <a href={siteData.instagramUrl} target="_blank" rel="noopener noreferrer">Instagram</a>
        )}
        {siteData.facebookUrl && (
          <a href={siteData.facebookUrl} target="_blank" rel="noopener noreferrer">Facebook</a>
        )}
        <a href="/mentions-legales">Mentions légales</a>
      </div>
    </div>
    <div class="footer-bottom">
      <div>© Joutes Inter-Pompiers de la Sarine {year}</div>
      <div>Bataillon Sarine — Compagnie Moncor</div>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    color: #fff;
    overflow: hidden;
    isolation: isolate;
    min-height: var(--cell-h);
    background:
      radial-gradient(40% 130% at 0% 50%, rgba(255,180,90,.45) 0%, rgba(255,180,90,0) 60%),
      radial-gradient(50% 130% at 100% 50%, rgba(11,14,40,.45) 0%, rgba(11,14,40,0) 60%),
      linear-gradient(90deg, #E8742C 0%, #B83A28 22%, #6F1D2E 50%, #2B2347 78%, #1B2447 100%);
  }
  .footer-inner {
    position: relative;
    z-index: 5;
    padding: 64px 0 28px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 48px;
    align-items: start;
  }
  .footer-logo {
    width: 140px;
    height: 140px;
  }
  .footer-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: brightness(0) saturate(100%) invert(60%) sepia(60%) saturate(1300%) hue-rotate(350deg) brightness(101%) contrast(95%);
  }
  .footer-info {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-cream-soft);
  }
  .footer-info .name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 18px;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: .04em;
    margin-bottom: 6px;
  }
  .footer-social {
    text-align: right;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 14px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: #fff;
    line-height: 2;
  }
  .footer-social a {
    display: block;
    color: inherit;
    text-decoration: none;
    cursor: pointer;
    transition: color .2s;
  }
  .footer-social a:hover {
    color: var(--color-orange-bright);
  }
  .footer-bottom {
    position: relative;
    z-index: 5;
    padding: 18px 0 28px;
    border-top: 1px solid rgba(255,255,255,.18);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 11px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(244,217,182,.7);
  }

  @media (max-width: 960px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 40px 0 24px;
    }
    .footer-logo {
      width: 96px;
      height: 96px;
    }
    .footer-social {
      text-align: left;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 8px;
      align-items: flex-start;
      padding: 16px 0 24px;
      font-size: 10px;
    }
  }

  @media (max-width: 480px) {
    .footer-logo { width: 72px; height: 72px; }
    .footer-info { font-size: 14px; }
    .footer-social { font-size: 13px; }
  }
</style>
